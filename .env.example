# Chave da API do Ollama (geração de resumos e respostas da IA)
API_KEY=sua_chave_ollama

# Credenciais de acesso à área administrativa
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Segredo usado para assinar os tokens de sessão do admin (HMAC).
# Use um valor longo e aleatório em produção.
AUTH_SECRET=troque-por-um-segredo-aleatorio
